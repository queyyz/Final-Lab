# ── Shared JWT Security (ต้องเหมือนกันทุก Service) ──────────────────
# เปลี่ยนเป็นรหัสสุ่มยาวๆ ก่อน Deploy จริง
JWT_SECRET=engse207-shared-jwt-secret-set2
JWT_EXPIRES=1h

# ── Database Credentials (ใช้ร่วมกันทั้ง 3 DB เพื่อความสะดวกใน Lab) ──
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret123

# 🚨 ข้อมูลชื่อฐานข้อมูล (สำหรับอ้างอิงใน docker-compose)
# Auth Service ใช้: authdb
# Task Service ใช้: taskdb
# User Service ใช้: userdb